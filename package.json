{
  "name": "relentnet",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @relentnet/marketing",
    "build": "npm run build -w @relentnet/marketing",
    "preview": "npm run preview -w @relentnet/marketing",
    "test": "npm run test -w @relentnet/marketing",
    "lint": "npm run lint -w @relentnet/marketing",
    "typecheck": "npm run typecheck -w @relentnet/marketing",
    "format": "prettier --write .",
    "check": "prettier --write . && eslint --fix"
  },
  "devDependencies": {
    "@tanstack/eslint-config": "^0.3.0",
    "prettier": "^3.5.3"
  }
}
